# Slugger Secret Configuration
#
# Copy this file to config/secrets.yaml and fill in your credentials.
# WARNING: config/secrets.yaml is excluded from version control.
#          Never commit it to the repository.
#
# Values in this file override the corresponding entries in defaults.yaml.
# You may also supply credentials via the environment variables shown below
# instead of filling them in here.

# ── AI Provider credentials ────────────────────────────────────────────────────

providers:
  # Set to 'openai' or 'anthropic' to use a real model by default.
  # Leave as 'mock' for offline / test use.
  default_provider: mock

  configs:

    openai:
      provider_type: openai
      # Available models: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-3.5-turbo
      model: gpt-4o
      # Paste your key here OR export OPENAI_API_KEY in your shell.
      api_key: YOUR_OPENAI_API_KEY_HERE
      # Optional: override the base URL for Azure OpenAI or a compatible endpoint.
      # base_url: https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT

    anthropic:
      provider_type: anthropic
      # Available models: claude-3-5-sonnet-20241022, claude-3-haiku-20240307, claude-3-opus-20240229
      model: claude-3-5-sonnet-20241022
      # Paste your key here OR export ANTHROPIC_API_KEY in your shell.
      api_key: YOUR_ANTHROPIC_API_KEY_HERE

# ── GitHub integration ─────────────────────────────────────────────────────────

github:
  # GitHub personal access token (classic) or fine-grained token.
  # Required scopes: repo (read/write issues, PRs, comments).
  # Paste your token here OR export GITHUB_TOKEN in your shell.
  token: YOUR_GITHUB_TOKEN_HERE
  # Default repository for GitHub operations.
  owner: your-github-username-or-org
  repo: your-repository-name

# ── Canva Connect API ──────────────────────────────────────────────────────────

canva:
  # Canva Connect API access token.
  # Generate one at https://www.canva.com/developers/ → Your integrations → Access tokens.
  # Paste your token here OR export CANVA_API_TOKEN in your shell.
  access_token: YOUR_CANVA_API_TOKEN_HERE
  # Optional: override the Canva API base URL (useful for testing or proxies).
  # base_url: https://api.canva.com/rest/v1
