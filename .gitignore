# logs/ directory is excluded from version control.
# Only the README.md that documents this directory is tracked.
logs/*
!logs/README.md

# Secret configuration — contains API keys and tokens. Never commit this file.
config/secrets.yaml

# Packaging build artifacts
*.egg-info/

# Python cache and test artifacts
__pycache__/
*.py[cod]
.pytest_cache/

# Runtime state and persistence files
workflow/state.json
*.db
*.db-shm
*.db-wal
*.sqlite3-shm
*.sqlite3-wal
artifacts/
workspace_*/
slugger_workspace*/
dist/
build/
